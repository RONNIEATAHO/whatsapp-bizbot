<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/rt"
        android:scaleType="centerCrop"
        android:alpha="0.2" />

    <LinearLayout
        android:id="@+id/warningContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:elevation="8dp">

        <!-- Status Warning -->
        <TextView
            android:id="@+id/tvStatusWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFF00"
            android:padding="12dp"
            android:text="Warning: Services not enabled! Tap here to fix."
            android:textColor="#000000"
            android:textStyle="bold"
            android:textAlignment="center"
            android:visibility="gone"/>

        <!-- Network Warning -->
        <TextView
            android:id="@+id/tvNetworkWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF0000"
            android:padding="12dp"
            android:text="No Internet Connection"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAlignment="center"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Landing Page (Permission Request) -->
    <LinearLayout
        android:id="@+id/layoutLanding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="223dp"
            android:src="@drawable/rt" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Welcome to BizBot"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="BizBot automatically extracts orders from your WhatsApp chats and organizes them here for you."
            android:textAlignment="center"
            android:textColor="#444444"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp"/>

        <Button
            android:id="@+id/btnEnable"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="@android:color/holo_green_dark"
            android:text="Get Started"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Orders Dashboard -->
    <LinearLayout
        android:id="@+id/layoutOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_below="@id/warningContainer"
        android:layout_alignParentBottom="true">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DDFFFFFF"
            app:tabSelectedTextColor="@android:color/holo_green_dark"
            app:tabIndicatorColor="@android:color/holo_green_dark">
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unread" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read" />
        </com.google.android.material.tabs.TabLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Live Orders"
            android:padding="16dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="#DDFFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvNoOrders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No orders yet."
            android:textAlignment="center"
            android:textSize="20sp"
            android:textColor="#666666"
            android:visibility="gone"
            android:padding="24dp" />

        <TextView
            android:id="@+id/tvExportHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="Tip: Shake your phone to unlock Export options"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontStyle="italic" />

    </LinearLayout>

    <Button
        android:id="@+id/btnExport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="100dp"
        android:backgroundTint="@android:color/holo_blue_dark"
        android:text="Export to Excel"
        android:textSize="18sp"
        android:padding="16dp"
        android:elevation="10dp"
        android:visibility="gone" />

</RelativeLayout>
